# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Hand Gesture Recognition — Environment Configuration
# Copy this file to .env and fill in your values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━ Database ━━━
DATABASE_URL=sqlite:///./gesture_recognition.db
# For PostgreSQL: postgresql://user:password@localhost:5432/gesture_recognition

# ━━━ Authentication ━━━
SECRET_KEY=change-me-run-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ━━━ Kaggle (for dataset download) ━━━
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ━━━ AI Model ━━━
INFERENCE_MODE=image
# Options: image | landmark
MODEL_BACKBONE=cnn
# Options: cnn | mobilenetv2 | efficientnetb0
MODEL_PATH=models/best_model.keras
CLASS_NAMES_PATH=models/class_names.json

# ━━━ Server ━━━
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ━━━ Frontend ━━━
VITE_API_URL=http://localhost:8000
